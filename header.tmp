<!DOCTYPE html>
<!-- saved from url=(0061)file:///C:/Users/user/Desktop/mnm_thriftshop_final%20(1).html -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MNM Thriftshop</title>
<link href="./MNM Thriftshop_files/css2" rel="stylesheet">
<style>
  :root {
    --black: #050505;
    --off-white: #f5f5f5;
    --gold: #c5a059;
    --accent: #e56b1f; /* A cleaner rust/orange */
    --gray: #888;
    --dark-gray: #1a1a1a;
  }
  
  * { 
    margin: 0; 
    padding: 0; 
    box-sizing: border-box; 
    -webkit-font-smoothing: antialiased;
  }
  
  body { 
    background: var(--black); 
    color: var(--off-white); 
    font-family: 'DM Mono', monospace; 
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* Global Animations */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Header */
  header { 
    position: fixed; 
    top: 0; 
    left: 0; 
    right: 0; 
    z-index: 1000; 
    background: rgba(5, 5, 5, 0.9); 
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--dark-gray); 
  }
  
  .header-top { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    padding: 1.5rem 2rem; 
  }
  
  .logo { 
    font-family: 'Bebas Neue', sans-serif; 
    font-size: 1.8rem; 
    letter-spacing: 0.2em; 
    font-weight: 400;
  }
  
  .logo span { color: var(--accent); }
  
  nav { display: flex; gap: 2rem; }
  
  nav a { 
    font-size: 0.7rem; 
    letter-spacing: 0.25em; 
    text-transform: uppercase; 
    color: var(--gray); 
    text-decoration: none; 
    transition: color 0.3s; 
  }
  
  nav a:hover { color: var(--off-white); }
  
  .ig-link { 
    font-size: 0.65rem; 
    letter-spacing: 0.2em; 
    text-transform: uppercase; 
    color: var(--accent); 
    text-decoration: none; 
    border: 1px solid var(--accent); 
    padding: 0.5rem 1.2rem; 
    transition: all 0.3s; 
  }
  
  .ig-link:hover { 
    background: var(--accent); 
    color: var(--black); 
  }

  /* Marquee */
  .marquee-bar { 
    background: var(--accent); 
    padding: 8px 0; 
    overflow: hidden; 
  }
  
  .marquee-inner { 
    display: inline-block; 
    white-space: nowrap;
    animation: marquee 25s linear infinite; 
  }
  
  .marquee-inner span { 
    font-size: 0.65rem; 
    letter-spacing: 0.3em; 
    text-transform: uppercase; 
    color: var(--black); 
    margin: 0 3rem; 
    font-weight: 600;
  }
  
  @keyframes marquee { 
    from { transform: translateX(0); } 
    to { transform: translateX(-50%); } 
  }

  /* Hero / Featured */
  .featured { 
    padding-top: 180px; 
    padding-bottom: 100px;
    background: var(--black);
  }
  
  .featured-item { 
    display: grid; 
    grid-template-columns: 1.2fr 0.8fr; 
    gap: 4rem; 
    align-items: center;
    margin-bottom: 6rem;
    padding: 0 4rem;
  }

  .featured-item:nth-child(even) {
    direction: rtl;
  }
  
  .featured-item:nth-child(even) .featured-info {
    direction: ltr;
  }

  .featured-img-wrap { 
    position: relative;
    overflow: hidden; 
    aspect-ratio: 16/9;
  }
  
  .featured-img-wrap img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    transition: transform 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .featured-item:hover img { transform: scale(1.05); }
  
  .featured-info { 
    display: flex; 
    flex-direction: column; 
    gap: 1.5rem;
  }
  
  .featured-brand { 
    font-size: 0.7rem; 
    letter-spacing: 0.4em; 
    color: var(--accent); 
    text-transform: uppercase; 
  }
  
  .featured-title { 
    font-family: 'Playfair Display', serif; 
    font-size: clamp(2rem, 5vw, 4rem); 
    font-style: italic; 
    line-height: 1.1;
  }
  
  .featured-desc { 
    font-size: 0.8rem; 
    color: var(--gray); 
    max-width: 400px;
    line-height: 1.8;
  }

  /* Products Section */
  .products { 
    background: #080808; 
    padding: 100px 2rem;
  }
  
  .section-header { 
    margin-bottom: 4rem; 
    text-align: center;
  }
  
  .section-title { 
    font-family: 'Bebas Neue', sans-serif; 
    font-size: 3.5rem; 
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }
  
  .section-sub { 
    font-size: 0.7rem; 
    letter-spacing: 0.3em; 
    color: var(--gray); 
    text-transform: uppercase; 
  }

  .product-grid { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 1.5rem; 
  }
  
  .product-card { 
    position: relative; 
    aspect-ratio: 4/5; 
    overflow: hidden; 
    background: var(--dark-gray);
  }
  
  .product-img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .product-card:hover .product-img { transform: scale(1.08); }
  
  .product-overlay { 
    position: absolute; 
    inset: 0;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .product-card:hover .product-overlay { opacity: 1; }
  
  .product-name { 
    font-family: 'Bebas Neue', sans-serif; 
    font-size: 1.5rem; 
    letter-spacing: 0.05em; 
  }
  
  .product-brand { 
    font-size: 0.65rem; 
    letter-spacing: 0.2em; 
    color: var(--accent); 
    text-transform: uppercase;
  }

  /* About */
  .about { padding: 120px 4rem; }
  .about-inner { 
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    gap: 6rem; 
    align-items: center; 
  }
  
  .about-text h2 { 
    font-family: 'Bebas Neue', sans-serif; 
    font-size: 4rem; 
    margin-bottom: 2rem; 
  }

  /* Contact */
  .contact { 
    background: var(--black); 
    text-align: center; 
    padding: 120px 2rem;
    border-top: 1px solid var(--dark-gray);
  }
  
  .contact h2 { 
    font-family: 'Bebas Neue', sans-serif; 
    font-size: 4rem; 
    margin-bottom: 1.5rem; 
  }
  
  .contact-ig { 
    display: inline-block; 
    color: var(--accent); 
    font-size: 1rem; 
    text-decoration: none; 
    letter-spacing: 0.2em; 
    border-bottom: 1px solid var(--accent);
    padding-bottom: 5px;
    transition: all 0.3s;
  }

  .contact-ig:hover { color: var(--off-white); border-color: var(--off-white); }

  @media (max-width: 1024px) {
    .featured-item { grid-template-columns: 1fr; padding: 0 2rem; gap: 2rem; }
    .product-grid { grid-template-columns: repeat(2, 1fr); }
    .about-inner { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .product-grid { grid-template-columns: 1fr; }
    .logo { font-size: 1.5rem; }
    .header-top { padding: 1rem; }
  }
</style>
</head>
<body>

<header>
  <div class="header-top">
    <div class="logo">M<span>&amp;</span>M</div>
    <nav>
      <a href="#products">Shop</a>
      <a href="#featured">Featured</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </nav>
    <a href="https://www.instagram.com/mnm_thriftshop" target="_blank" class="ig-link">@mnm_thriftshop</a>
  </div>
  <div class="marquee-bar">
    <div class="marquee-inner">
      <span>Carhartt</span><span>·</span><span>Timberland</span><span>·</span><span>Harley-Davidson</span><span>·</span><span>Stüssy</span><span>·</span><span>Vintage Denim</span><span>·</span><span>Workwear</span><span>·</span><span>Mnm Thriftshop</span><span>·</span>
      <span>Carhartt</span><span>·</span><span>Timberland</span><span>·</span><span>Harley-Davidson</span><span>·</span><span>Stüssy</span><span>·</span><span>Vintage Denim</span><span>·</span><span>Workwear</span><span>·</span><span>Mnm Thriftshop</span><span>·</span>
    </div>
  </div>
</header>
